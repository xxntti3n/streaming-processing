FROM ubuntu:22.04

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install mysql-client
RUN apt-get update && \
    apt-get install -y mysql-client coreutils && \
    rm -rf /var/lib/apt/lists/*

# Copy the insertion script
COPY insert-sales-data-loop.sh /usr/local/bin/insert-data.sh
RUN chmod +x /usr/local/bin/insert-data.sh

# Run the script in a loop (every 10 seconds)
CMD ["/usr/local/bin/insert-data.sh"]
